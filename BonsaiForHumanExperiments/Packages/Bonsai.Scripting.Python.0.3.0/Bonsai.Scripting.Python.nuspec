<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Bonsai.Scripting.Python</id>
    <version>0.3.0</version>
    <title>Bonsai - Python Scripting Library</title>
    <authors>Bonsai Foundation</authors>
    <license type="file">LICENSE</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <projectUrl>https://bonsai-rx.org/python-scripting</projectUrl>
    <description>Bonsai Scripting Library for interfacing with the Python runtime.</description>
    <copyright>Copyright © Bonsai Foundation CIC and Contributors</copyright>
    <tags>Bonsai Rx Scripting Python Python.NET</tags>
    <packageTypes>
      <packageType name="Dependency" />
      <packageType name="BonsaiLibrary" />
    </packageTypes>
    <repository type="git" url="https://github.com/bonsai-rx/python-scripting" commit="c15107aca6ce374c66761a54eb73637955183a2e" />
    <dependencies>
      <group targetFramework=".NETFramework4.7.2">
        <dependency id="Bonsai.Core" version="2.7.0" exclude="Build,Analyzers" />
        <dependency id="pythonnet" version="3.0.5" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Bonsai.Core" version="2.7.0" exclude="Build,Analyzers" />
        <dependency id="pythonnet" version="3.0.5" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>