<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>EmotionalCities.Lsl</id>
    <version>0.4.1</version>
    <title>Emotional Cities - LSL Library</title>
    <authors>NeuroGEARS</authors>
    <license type="file">LICENSE</license>
    <licenseUrl>https://aka.ms/deprecateLicenseUrl</licenseUrl>
    <icon>icon.png</icon>
    <projectUrl>https://emotional-cities.github.io/lsl</projectUrl>
    <description>Bonsai Library containing interfaces for streaming data from devices implementing the LSL protocol.</description>
    <copyright>Copyright © NeuroGEARS Ltd 2022</copyright>
    <tags>Bonsai Rx LSL Lab Streaming Layer</tags>
    <repository type="git" url="https://github.com/emotional-cities/lsl.git" />
    <dependencies>
      <group targetFramework=".NETFramework4.7.2">
        <dependency id="Bonsai.Core" version="2.7.0" exclude="Build,Analyzers" />
        <dependency id="OpenCV.Net" version="3.4.1" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Bonsai.Core" version="2.7.0" exclude="Build,Analyzers" />
        <dependency id="OpenCV.Net" version="3.4.1" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>